NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-jwt-key-min-32-chars-long-change-in-production

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/edusphere?schema=public"
PRISMA_TENANT_SCHEMA_PATH="prisma/tenant/schema.prisma"

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# CORS
CORS_ORIGIN=http://localhost:5173

TENANT_BASE_URL_TEMPLATE="http://{{slug}}.localhost:8080"
TENANT_DEFAULT_SCHEME="http"
TWILIO_SENDGRID_API_KEY=
TWILIO_EMAIL_FROM="EduSphere <noreply@edusphere.com>"

# Cloudinary backend upload (optional: local storage is used if these are empty)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
