NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-jwt-key-min-32-chars-long-change-in-production

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/edusphere?schema=public"

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# CORS
CORS_ORIGIN=http://localhost:5173
